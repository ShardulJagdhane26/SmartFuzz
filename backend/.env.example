# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit it.

# Google AI Studio API key for Gemini payload synthesis.
GEMINI_API_KEY=

# Set to 1 to allow scans against localhost / RFC1918 private IPs
# (for local DVWA, Juice Shop, etc.). Leave 0 in production.
SMARTFUZZ_ALLOW_LOCAL=0

# Port the Flask backend listens on.
PORT=5000

# Directory where smartfuzz.db is stored. Leave unset for local dev (defaults
# to the backend/ folder). Set to /app/data on Render to use the persistent disk.
# DATA_DIR=
